<view class="page-edit">
  <view class="avatar-section">
    <button
      class="avatar-btn"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
    >
      <image class="avatar" src="{{avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
      <view class="camera-icon">📷</view>
    </button>
    <text class="avatar-tip">点击更换头像</text>
  </view>

  <view class="form-card">
    <view class="form-row">
      <text class="label">昵称</text>
      <input
        class="input"
        type="nickname"
        placeholder="输入你的昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="12"
      />
    </view>
  </view>

  <button class="save-btn" bindtap="save" loading="{{saving}}" disabled="{{!nickname || saving}}">保存</button>

  <view class="safe-bottom"></view>
</view>
