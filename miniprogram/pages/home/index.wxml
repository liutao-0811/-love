<view class="page-home">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-title">我们的空间</text>
    </view>
  </view>

  <scroll-view scroll-y class="scroll-area" style="padding-top: {{navBarHeight}}px;">
    <!-- 未绑定引导 -->
    <view class="unbound-guide fade-in" wx:if="{{!isBound}}">
      <text class="guide-icon">💕</text>
      <text class="guide-title">欢迎来到 Me Love</text>
      <text class="guide-desc">绑定情侣后，开启你们的专属空间</text>
      <button class="guide-btn" bindtap="goToBind">立即绑定</button>
    </view>

    <!-- 已绑定内容 -->
    <block wx:else>
    <!-- 情侣头像与天数卡片 -->
    <view class="hero-card fade-in">
      <view class="couple-avatars">
        <image class="avatar" src="{{coupleInfo.partner1.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="heart-icon">💖</view>
        <image class="avatar" src="{{coupleInfo.partner2.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
      </view>
      
      <view class="days-counter">
        <text class="days-label">羁绊建立</text>
        <view class="days-number">
          <text class="digit">{{displayDays}}</text>
          <text class="unit">天</text>
        </view>
      </view>

      <view class="bond-level">
        <view class="level-info">
          <text class="level-title">{{bondLevel.title}}</text>
          <text class="level-desc">距离下一阶段还需 {{bondLevel.nextThreshold - daysTogether}} 天</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{bondLevel.progress}}%"></view>
        </view>
      </view>
    </view>

    <!-- 天气与纪念日 -->
    <view class="info-row fade-in" style="animation-delay: 0.1s;">
      <view class="weather-card">
        <text class="weather-icon">{{weather.icon}}</text>
        <view class="weather-info">
          <text class="weather-temp">{{weather.temp}}°</text>
          <text class="weather-city">{{weather.city}}</text>
        </view>
      </view>
      
      <view class="anniversary-card">
        <text class="anni-icon">🎂</text>
        <view class="anni-info">
          <text class="anni-title">{{nextAnniversary.name}}</text>
          <text class="anni-days">还有 {{nextAnniversary.daysLeft}} 天</text>
        </view>
      </view>
    </view>

    <!-- 快捷功能入口 -->
    <view class="quick-actions fade-in" style="animation-delay: 0.2s;">
      <view class="action-item" bindtap="goToDiary">
        <view class="action-icon diary">📔</view>
        <text class="action-text">写日记</text>
      </view>
      <view class="action-item" bindtap="goToNotes">
        <view class="action-icon notes">💌</view>
        <text class="action-text">小纸条</text>
      </view>
      <view class="action-item" bindtap="goToCheckin">
        <view class="action-icon tasks">🩷</view>
        <text class="action-text">签到</text>
      </view>
      <view class="action-item" bindtap="goToCountdown">
        <view class="action-icon countdown">⏳</view>
        <text class="action-text">倒计时</text>
      </view>
    </view>

    <!-- 最近动态 -->
    <view class="recent-section fade-in" style="animation-delay: 0.3s;">
      <view class="section-header">
        <text class="section-title">最近动态</text>
      </view>
      
      <view class="recent-list">
        <block wx:if="{{recentActivities.length > 0}}">
          <view class="activity-item" wx:for="{{recentActivities}}" wx:key="id">
            <view class="activity-dot"></view>
            <view class="activity-content">
              <text class="activity-text">{{item.content}}</text>
              <text class="activity-time">{{item.timeStr}}</text>
            </view>
          </view>
        </block>
        <view wx:else class="empty-state">
          <text class="empty-icon">🌙</text>
          <text class="empty-text">还没有动态，快去记录你们的故事吧</text>
        </view>
      </view>
    </view>

    </block>

    <view class="safe-bottom"></view>
  </scroll-view>
</view>
